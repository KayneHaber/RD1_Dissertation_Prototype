{
  "name": "react-xss-linter",
  "version": "0.1.0",
  "description": "RD1 Milestone 2 prototype: a static analysis tool that detects XSS-prone patterns in React code and suggests fixes.",
  "main": "src/index.ts",
  "scripts": {
    "scan": "ts-node src/index.ts",
    "build": "tsc"
  },
  "keywords": [
    "xss",
    "react",
    "static-analysis",
    "security",
    "ast"
  ],
  "author": "Kayne Haber",
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.5",
    "@types/node": "^20.19.41",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
